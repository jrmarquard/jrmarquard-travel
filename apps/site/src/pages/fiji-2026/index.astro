---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import Layout from '../../layouts/Layout.astro';
import { trip } from '../../data/trips/fiji-diving-2026';
import type {
  AccommodationSegment,
  ActivitySegment,
  Day,
  FlightSegment,
  Location,
  NoteSegment,
  Segment,
  TransferSegment,
} from '../../schema/types';

const COUNTRY_FLAG: Record<string, string> = {
  FJ: '🇫🇯',
  AU: '🇦🇺',
};

const start = new Date(`${trip.dates.start}T00:00:00Z`);
const end = new Date(`${trip.dates.end}T00:00:00Z`);
const dayCount = Math.floor((end.getTime() - start.getTime()) / 86400000) + 1;

function formatDate(iso: string) {
  const d = new Date(`${iso}T12:00:00Z`);
  return d.toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
}

function formatShortDate(iso: string) {
  const d = new Date(`${iso}T12:00:00Z`);
  return d.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  });
}

function getPrimaryLocation(day: (typeof trip.days)[number]): Location | null {
  const stop = day.stops.find((s) => s.id === day.primaryStopId);
  if (!stop) return null;
  const loc = stop.location;
  return 'kind' in loc ? null : loc;
}

function toIsoDate(datetime: string) {
  return datetime.slice(0, 10);
}

function normalizeLabel(text: string) {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
}

function locationMatchesName(locationName: string, referenceName: string) {
  const a = normalizeLabel(locationName);
  const b = normalizeLabel(referenceName);
  return a.includes(b) || b.includes(a);
}

const accommodations = trip.segments
  .filter((segment): segment is AccommodationSegment => segment.type === 'accommodation')
  .sort((a, b) => a.checkIn.localeCompare(b.checkIn));

const flights = trip.segments.filter((segment): segment is FlightSegment => segment.type === 'flight');

function getPrimaryLocationName(day: Day) {
  const location = getPrimaryLocation(day);
  return location?.name ?? '';
}

function inferTransferDate(segment: TransferSegment) {
  const destination = segment.waypoints[segment.waypoints.length - 1].location.name;

  const byAccommodation = accommodations.find(
    (acc) => locationMatchesName(acc.name, destination) || locationMatchesName(acc.location.name, destination),
  );
  if (byAccommodation) return byAccommodation.checkIn;

  const byFlight = flights.find((flight) =>
    locationMatchesName(flight.legs[0].departure.location.name, destination),
  );
  if (byFlight) return toIsoDate(byFlight.legs[0].departure.datetime);

  const byTransferDayTitle = trip.days.find((day) => {
    const title = day.title ?? '';
    if (!/transfer/i.test(title)) return false;
    return locationMatchesName(getPrimaryLocationName(day), destination);
  });
  if (byTransferDayTitle) return byTransferDayTitle.date;

  return trip.dates.start;
}

function getSegmentDayKey(segment: Segment) {
  if (segment.type === 'flight') return toIsoDate(segment.legs[0].departure.datetime);
  if (segment.type === 'transfer') {
    const startDate = segment.waypoints[0].datetime;
    return startDate ? toIsoDate(startDate) : inferTransferDate(segment);
  }
  if (segment.type === 'activity') {
    if ('dates' in segment.schedule) return segment.schedule.dates[0];
    return segment.schedule.start;
  }
  if (segment.type === 'note') return segment.date;
  return segment.checkIn;
}

const transitByDay = new Map<string, (FlightSegment | TransferSegment)[]>();
for (const segment of trip.segments) {
  if (segment.type !== 'flight' && segment.type !== 'transfer') continue;
  const key = getSegmentDayKey(segment);
  const list = transitByDay.get(key) ?? [];
  list.push(segment);
  transitByDay.set(key, list);
}

const activitiesByDay = new Map<string, string[]>();

for (const segment of trip.segments) {
  if (segment.type !== 'activity') continue;

  const dates = 'dates' in segment.schedule ? segment.schedule.dates : expandDateRange(segment.schedule.start, segment.schedule.end);
  for (const date of dates) {
    const existing = activitiesByDay.get(date) ?? [];
    existing.push(formatActivityLabel(segment));
    activitiesByDay.set(date, existing);
  }
}

for (const segment of trip.segments) {
  if (segment.type !== 'note') continue;
  const existing = activitiesByDay.get(segment.date) ?? [];
  existing.push(segment.title);
  activitiesByDay.set(segment.date, existing);
}

function expandDateRange(startDate: string, endDate: string) {
  const output: string[] = [];
  let cursor = new Date(`${startDate}T00:00:00Z`);
  const endDateObj = new Date(`${endDate}T00:00:00Z`);
  while (cursor <= endDateObj) {
    output.push(cursor.toISOString().slice(0, 10));
    cursor = new Date(cursor.getTime() + 86400000);
  }
  return output;
}

function formatActivityLabel(segment: ActivitySegment) {
  return segment.category ? `${segment.name} (${segment.category})` : segment.name;
}

function accommodationForDate(date: string) {
  return accommodations.find((acc) => acc.checkIn <= date && acc.checkOut >= date) ?? null;
}

function startAccommodationForDay(date: string) {
  const checkoutToday = accommodations.find((acc) => acc.checkOut === date);
  if (checkoutToday) return checkoutToday;
  return accommodations.find((acc) => acc.checkIn < date && acc.checkOut >= date) ?? null;
}

function endAccommodationForDay(date: string) {
  const checkinToday = accommodations.find((acc) => acc.checkIn === date);
  if (checkinToday) return checkinToday;
  return accommodationForDate(date);
}

function formatAccommodation(segment: AccommodationSegment | null) {
  if (!segment) return 'No accommodation logged';
  const room = segment.roomType ? ` (${segment.roomType})` : '';
  return `${segment.name}${room}`;
}

function getAccommodationMergeKey(segment: AccommodationSegment | null) {
  if (!segment) return '';
  return normalizeLabel(`${segment.name} ${segment.location.name} ${segment.roomType ?? ''}`);
}

function getTransitOrigin(segment: FlightSegment | TransferSegment) {
  if (segment.type === 'flight') return segment.legs[0].departure.location.name;
  return segment.waypoints[0].location.name;
}

function getTransitDestination(segment: FlightSegment | TransferSegment) {
  if (segment.type === 'flight') return segment.legs[segment.legs.length - 1].arrival.location.name;
  return segment.waypoints[segment.waypoints.length - 1].location.name;
}

function formatStartLine(item: TimelineDay) {
  if (item.startStay) return formatAccommodation(item.startStay);
  if (item.transit.length > 0) return getTransitOrigin(item.transit[0]);
  return '';
}

function formatEndLine(item: TimelineDay) {
  const checkinToday = item.endStay && item.endStay.checkIn === item.day.date;
  if (checkinToday) return formatAccommodation(item.endStay);
  if (item.transit.length > 0) return getTransitDestination(item.transit[item.transit.length - 1]);
  return formatAccommodation(item.endStay);
}

function formatTransitTitle(segment: FlightSegment | TransferSegment) {
  if (segment.type === 'flight') {
    const first = segment.legs[0];
    const last = segment.legs[segment.legs.length - 1];
    return `${first.departure.location.name} -> ${last.arrival.location.name}`;
  }

  const first = segment.waypoints[0].location;
  const last = segment.waypoints[segment.waypoints.length - 1].location;
  return `${first.name} -> ${last.name}`;
}

function formatTransitMeta(segment: FlightSegment | TransferSegment) {
  if (segment.type === 'flight') {
    const numbers = segment.legs.map((leg) => leg.flightNumber.trim()).filter(Boolean);
    return numbers.join(' · ');
  }

  const stops = segment.waypoints.slice(1, -1).map((point) => point.location.name);
  return stops.length ? `Stops: ${stops.join(' · ')}` : '';
}

function sortTransitSegments(segments: (FlightSegment | TransferSegment)[]) {
  return [...segments].sort((a, b) => {
    const aDate = a.type === 'flight' ? a.legs[0].departure.datetime : a.waypoints[0].datetime ?? '';
    const bDate = b.type === 'flight' ? b.legs[0].departure.datetime : b.waypoints[0].datetime ?? '';
    return aDate.localeCompare(bDate);
  });
}

interface TimelineDay {
  day: Day;
  index: number;
  transit: (FlightSegment | TransferSegment)[];
  hasTransit: boolean;
  startStay: AccommodationSegment | null;
  endStay: AccommodationSegment | null;
  activeStay: AccommodationSegment | null;
  rowUnits: number;
  activities: string[];
  mergeSpan: number;
  mergeStart: boolean;
}

const timelineDays: TimelineDay[] = trip.days.map((day, i) => {
  const transit = sortTransitSegments(transitByDay.get(day.date) ?? []);
  const hasTransit = transit.length > 0;
  const startStay = startAccommodationForDay(day.date);
  const endStay = endAccommodationForDay(day.date);
  const activeStay = endStay ?? startStay;
  const activities = activitiesByDay.get(day.date) ?? [];

  return {
    day,
    index: i + 1,
    transit,
    hasTransit,
    startStay,
    endStay,
    activeStay,
    rowUnits: hasTransit ? 3 : 1,
    activities,
    mergeSpan: 1,
    mergeStart: false,
  };
});

for (let i = 0; i < timelineDays.length; i += 1) {
  const current = timelineDays[i];
  if (!current.activeStay) continue;
  
  const currentMergeKey = getAccommodationMergeKey(current.activeStay);

  // For transit days with end stay
  if (current.hasTransit && current.endStay && getAccommodationMergeKey(current.endStay) === currentMergeKey) {
    if (i > 0) {
      const previous = timelineDays[i - 1];
      if (getAccommodationMergeKey(previous.activeStay) === currentMergeKey) {
        continue; // Skip if previous day already uses same accommodation
      }
    }

    // Calculate span: 3 rows for transit + subsequent days with same accommodation
    let span = 3;
    for (let j = i + 1; j < timelineDays.length; j += 1) {
      const next = timelineDays[j];
      if (next.hasTransit) break;
      if (getAccommodationMergeKey(next.activeStay) !== currentMergeKey) break;
      span += 1;
    }
    current.mergeStart = true;
    current.mergeSpan = span;
  }
  // For non-transit days
  else if (!current.hasTransit) {
    if (i > 0) {
      const previous = timelineDays[i - 1];
      if (!previous.hasTransit && getAccommodationMergeKey(previous.activeStay) === currentMergeKey) {
        continue;
      }
    }

    let span = 1;
    for (let j = i + 1; j < timelineDays.length; j += 1) {
      const next = timelineDays[j];
      if (next.hasTransit) break;
      if (getAccommodationMergeKey(next.activeStay) !== currentMergeKey) break;
      span += 1;
    }
    current.mergeStart = true;
    current.mergeSpan = span;
  }
}

// Compute which day indices are covered by spanning accommodation cells
const accommodationCoveredIndices = new Set<number>();
for (let i = 0; i < timelineDays.length; i += 1) {
  const item = timelineDays[i];
  if (item.mergeStart && item.mergeSpan > 1) {
    // Mark all following rows as covered by this span
    for (let j = 1; j < item.mergeSpan; j += 1) {
      accommodationCoveredIndices.add(i + j);
    }
  }
}

function shouldRenderMergedAccommodationCell(item: TimelineDay) {
  if (item.hasTransit) return false;
  return item.mergeStart;
}

function isAccommodationCovered(index: number): boolean {
  return accommodationCoveredIndices.has(index);
}

function formatTransitPrefix(segment: FlightSegment | TransferSegment) {
  if (segment.type === 'flight') return '✈️ Flight';

  const mode = segment.mode?.toLowerCase() ?? '';
  if (mode.includes('boat') || mode.includes('ferry')) return '⛴️ Boat transfer';
  if (mode.includes('road') || mode.includes('drive') || mode.includes('car') || mode.includes('vehicle')) {
    return '🚗 Drive';
  }
  if (mode.includes('bus') || mode.includes('shuttle')) return '🚌 Shuttle';
  return segment.mode ? `🧭 ${segment.mode}` : '❓';
}

function formatTransitLine(segment: FlightSegment | TransferSegment) {
  const title = formatTransitTitle(segment);
  if (segment.type === 'transfer' && !segment.mode) {
    const first = segment.waypoints[0].location.name;
    const last = segment.waypoints[segment.waypoints.length - 1].location.name;
    return `${formatTransitPrefix(segment)} ${first} -> ??? -> ${last}`;
  }
  return `${formatTransitPrefix(segment)}: ${title}`;
}

const hasMap = existsSync(join(process.cwd(), 'public', 'maps', `${trip.id}.png`));

function getMapsUrl(locationName: string): string {
  return `https://www.google.com/maps/search/${encodeURIComponent(locationName)}`;
}

function getTransitMapsUrl(segment: FlightSegment | TransferSegment): string {
  const from = getTransitOrigin(segment);
  const to = getTransitDestination(segment);
  return getMapsUrl(`${from} to ${to}`);
}
---

<Layout title={`${trip.title} - ${trip.dates.start}`} description={trip.description}>
  <nav>
    <a href="/" class="back">← Travel</a>
  </nav>

  <header class="trip-header">
    <h1>{trip.title}</h1>
    <p class="dates">{formatDate(trip.dates.start)} – {formatDate(trip.dates.end)}</p>
  </header>
  
  <section class="meta-strip">
    <div class="meta-item">
      <span class="meta-label">Duration</span>
      <span>{dayCount} days</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Country</span>
      <span>{trip.countries.map((c) => COUNTRY_FLAG[c] ?? c).join(' ')}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Theme</span>
      <span>{trip.tags?.join(' · ')}</span>
    </div>
  </section>

  {hasMap && (
    <section class="trip-map">
      <img src={`/maps/${trip.id}.png`} alt={`Route map for ${trip.title}`} />
    </section>
  )}

  <section class="timeline">
    <h2>Day Timeline</h2>
    <div class="table-wrap">
      <table>
        <colgroup>
          <col class="col-index" />
          <col class="col-date" />
          <col class="col-transit" />
          <col class="col-activity" />
        </colgroup>
        <thead>
          <tr>
            <th>#</th>
            <th>Date</th>
            <th>Transit + Accommodation</th>
            <th>Activities / Notes</th>
          </tr>
        </thead>
        <tbody>
          {timelineDays.map((item) => {
            if (item.hasTransit) {
              return (
                <>
                  <tr class="day-group-start">
                    <td rowspan={3} class="day-index">{item.index}</td>
                    <td rowspan={3}>
                      <div class="date-main">{formatShortDate(item.day.date)}</div>
                      <div class="date-sub">{formatDate(item.day.date)}</div>
                    </td>
                    <td>
                      <span class="line-value">
                        <a href={getMapsUrl(formatStartLine(item))} target="_blank" rel="noopener noreferrer">{formatStartLine(item)}</a>
                      </span>
                    </td>
                    <td rowspan={3}>
                      <ul class="activity-list">
                        {item.activities.length ? item.activities.map((entry) => <li>{entry}</li>) : <li>{item.day.title ?? 'Travel day'}</li>}
                      </ul>
                    </td>
                  </tr>
                  <tr class="day-group-transit">
                    <td>
                      {item.transit.map((segment) => (
                        <div class="transit-line">
                          <div class="line-value">
                            <a href={getTransitMapsUrl(segment)} target="_blank" rel="noopener noreferrer">{formatTransitLine(segment)}</a>
                          </div>
                          {formatTransitMeta(segment) ? <div class="line-meta">{formatTransitMeta(segment)}</div> : null}
                        </div>
                      ))}
                    </td>
                  </tr>
                  <tr>
                    <td>
                      <span class="line-value">
                        <a href={getMapsUrl(formatEndLine(item))} target="_blank" rel="noopener noreferrer">{formatEndLine(item)}</a>
                      </span>
                    </td>
                  </tr>
                </>
              );
            }

            return (
              <tr class="day-group-start">
                <td class="day-index">{item.index}</td>
                <td>
                  <div class="date-main">{formatShortDate(item.day.date)}</div>
                  <div class="date-sub">{formatDate(item.day.date)}</div>
                </td>
                {shouldRenderMergedAccommodationCell(item) ? (
                  <td rowspan={item.mergeSpan} class="merged-stay">
                    <span class="line-value">{formatAccommodation(item.activeStay)}</span>
                  </td>
                ) : null}
                <td>
                  <ul class="activity-list">
                    {item.activities.length ? item.activities.map((entry) => <li>{entry}</li>) : <li>{item.day.title ?? 'Day at resort'}</li>}
                  </ul>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
</Layout>

<style>
  :global(main) {
    max-width: none;
  }

  nav {
    margin-bottom: 2.5rem;
  }

  .back {
    font-size: 0.82rem;
    color: var(--muted);
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--text);
  }

  .trip-header {
    margin-bottom: 2rem;
  }

  .trip-header h1 {
    font-size: clamp(2.2rem, 6vw, 3.8rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 0.4rem;
  }

  .dates {
    font-size: 1rem;
    color: var(--muted);
    margin: 0;
    font-weight: 400;
  }

  .meta-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2.5rem;
    margin-bottom: 2.5rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    font-size: 0.88rem;
    gap: 0.15rem;
  }

  .meta-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .trip-map {
    margin-bottom: 2.5rem;
  }

  .trip-map img {
    width: 100%;
    display: block;
    border-radius: 4px;
  }

  .timeline {
    margin-bottom: 2.5rem;
  }

  .timeline h2 {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1rem;
  }

  .table-wrap {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 0;
    table-layout: auto;
  }

  .col-index {
    width: 5.5rem;
  }

  .col-date {
    width: 16.5rem;
  }

  .col-transit {
    width: 38%;
  }

  .col-activity {
    width: auto;
  }

  th,
  td {
    text-align: left;
    vertical-align: top;
    padding: 0.75rem 0.55rem;
    border-bottom: 1px solid var(--border);
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  th {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  tbody tr.day-group-start td {
    border-top: 1px solid var(--border);
  }

  tbody tr.day-group-transit td {
    height: 1.5rem;
    min-height: 1.5rem;
    padding: 1.5rem 0.55rem;
    vertical-align: middle;
  }

  .day-index {
    width: 3rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .date-main {
    font-size: 0.88rem;
    font-weight: 600;
  }

  .date-sub {
    color: var(--muted);
    font-size: 0.75rem;
    margin-top: 0.15rem;
  }

  .line-label {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.65rem;
    margin-right: 0.45rem;
  }

  .line-value {
    font-size: 0.88rem;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  .line-meta {
    margin-top: 0.2rem;
    color: var(--muted);
    font-size: 0.76rem;
  }

  .transit-line {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .transit-line + .transit-line {
    margin-top: 0.45rem;
  }

  .activity-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.84rem;
  }

  .activity-list li {
    margin: 0;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  .merged-stay {
    background: #fafafa;
    vertical-align: middle;
  }

  /* CSS Grid Timeline */
  .timeline-grid {
    margin-top: 4rem;
  }

  .grid-wrap {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .timeline-grid-header {
    display: grid;
    grid-template-columns: 5.5rem 16.5rem 1fr auto;
    gap: 0;
    padding: 0.9rem 0.55rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--bg-elevated, #f8f8f8);
  }

  .timeline-grid-body {
    display: grid;
    grid-template-columns: 5.5rem 16.5rem 1fr auto;
    grid-auto-rows: auto;
    gap: 0;
    position: relative;
  }

  .grid-row {
    display: grid;
    grid-template-columns: subgrid;
    grid-column: 1 / -1;
    border-bottom: 1px solid var(--border);
  }

  .grid-row > div {
    padding: 0.75rem 0.55rem;
    text-align: left;
    vertical-align: top;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .grid-day-index {
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .grid-date {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .grid-transit {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    justify-content: center;
  }

  .transit-section {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .transit-section:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .section-label {
    font-size: 0.65rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: none;
  }

  .grid-accommodation {
    padding: 0.75rem 0.55rem;
    background: #fafafa;
  }

  .grid-accommodation-overlay {
    grid-column: 3;
